{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true
  },
  "baseUrl": "src",
  "paths": {
    "*": ["*"]
  },
  "include": ["src"],
  "exclude": ["src/**/**/__mocks__/**/**"]
}
